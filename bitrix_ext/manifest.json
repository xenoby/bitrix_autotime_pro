{
  "manifest_version": 3,
  "name": "Bitrix Auto-Time Pro",
  "version": "2.0",
  "description": "Автоматизация через REST API",
  "icons": { "128": "bitrix.png" },
  "permissions": ["alarms", "notifications", "storage"],
  "host_permissions": ["https://*.bitrix24.ru/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" }
}